# Environment Variables Template
# Copy this to .env and fill in your actual values

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production

# MongoDB Connection (Use MongoDB Atlas - free tier available)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/smart_skill_exchange?retryWrites=true&w=majority

# Port (usually set by hosting provider)
PORT=5005
